CI_ENVIRONMENT = development

#--------------------------------------------------------------------
# APP
#--------------------------------------------------------------------
# Base URL Configuration
# Pilih salah satu opsi di bawah sesuai kebutuhan:
#
# Opsi 1 - Localhost (untuk development lokal):
# app.baseURL = 'http://localhost/imut-rsds/public/'
#
# Opsi 2 - IP Address (untuk akses dari komputer lain di jaringan lokal):
# app.baseURL = 'http://192.168.31.47/imut-rsds/public/'
#
# Opsi 3 - Domain (untuk production):
# app.baseURL = 'https://yourdomain.com/'
#
# Catatan: 
# - Pastikan URL diakhiri dengan slash (/)
# - Ganti IP address dengan IP server Anda (gunakan: ipconfig | findstr "IPv4")
# - Untuk production, gunakan HTTPS dan domain yang valid

#--------------------------------------------------------------------
# DATABASE
#--------------------------------------------------------------------
# Database Hostname Configuration
# Pilih salah satu opsi di bawah sesuai kebutuhan:
#
# Opsi 1 - Localhost (database di komputer yang sama dengan aplikasi):
# database.default.hostname = localhost
#
# Opsi 2 - IP Address (database di komputer/server lain):
# database.default.hostname = 192.168.31.47
#
# Opsi 3 - Domain/Host (untuk production):
# database.default.hostname = db.yourdomain.com
#
# Catatan: 
# - Pastikan MySQL/MariaDB sudah dikonfigurasi untuk menerima koneksi remote
# - Untuk koneksi remote, user MySQL harus memiliki akses dari host tersebut
# - Gunakan perintah: GRANT ALL ON database.* TO 'user'@'IP_ADDRESS' IDENTIFIED BY 'password';

database.default.database = imut-rsds
database.default.username = root
database.default.password =
database.default.DBDriver = MySQLi
database.default.port = 3306
